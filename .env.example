# 카카오 개발자 콘솔(https://developers.kakao.com)에서 JavaScript 키 발급
# 플랫폼 > Web 도메인 등록 필요 (로컬: http://localhost:5173, 배포 URL)
VITE_KAKAO_APP_KEY=your_kakao_javascript_key_here

# 기존 카카오맵 연동 호환용 (VITE_KAKAO_APP_KEY와 동일 키 사용 가능)
VITE_KAKAO_MAP_APP_KEY=your_kakao_javascript_key_here

# [채널 개설 후 설정] 카카오톡 채널 프로필 ID
# 채널 관리자센터 > 채널 정보 > 채널 URL의 pf.kakao.com/ 이후 값 (예: _ZeUTxl)
# 미설정 시: "채널 오픈 예정" UI 표시 / 설정 후 재배포하면 자동 연동
# VITE_KAKAO_CHANNEL_ID=_your_channel_id

# [Cloudflare Pages Variables] 관리자 로그인 비밀번호
# 미설정 시 기본값 graceshop 사용 (프로덕션에서는 반드시 변경)
# ADMIN_PASSWORD=your_secure_admin_password

# [Cloudflare Pages Variables — 런타임] 카카오 JavaScript 키
# wrangler pages deploy(로컬 빌드) 시에도 지도가 동작하려면 아래를 Pages Variables에 설정하세요.
# (빌드 재배포 없이 /api/config 로 즉시 반영)
# KAKAO_APP_KEY=your_kakao_javascript_key_here
# KAKAO_CHANNEL_ID=_your_channel_id
